# Clerk production environment — copy to .env, fill, NEVER commit.
# Every value below is required; server.mjs refuses to boot if any is missing.

# --- Supabase (Dashboard → Settings → API) ---
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_SERVICE_KEY=          # service_role key. Server-side ONLY. Bypasses RLS by design.

# --- LLM ---
ANTHROPIC_API_KEY=

# --- X Layer ---
# Mainnet: https://rpc.xlayer.tech (chainId 196) | Testnet: https://testrpc.xlayer.tech/terigon (1952)
XLAYER_RPC=https://rpc.xlayer.tech
CLERK_LEDGER_ADDRESS=          # ClerkLedgerV2 address after deployment

# --- Keys (see PRODUCTION.md "Key ceremony" before generating) ---
OPERATOR_PRIVATE_KEY=          # HOT key: signs registerTicket/submitResolution/ratings.
                               # Holds gas OKB only. NOT the payout wallet, NOT the deployer.

# --- Service secrets (generate: openssl rand -hex 32) ---
WEBHOOK_SECRET=                # shared with the ticket-system webhook sender (HMAC-SHA256)
RATING_TOKEN_SECRET=           # signs customer one-tap rating links
ADMIN_TOKEN=                   # bearer token for /admin/pause — treat like a root password
TRAIN_SESSION_SECRET=          # signs the merchant dashboard's "train Clerk" wallet-login session

# --- Public ---
PUBLIC_BASE_URL=https://clerk.yourdomain.com   # where /rate/:token links point
PORT=8080

# --- X Layer network selection ---
XLAYER_NETWORK=mainnet         # mainnet (196) or testnet (1952). RPC failover is automatic.

# --- OKX DEX aggregator (OPTIONAL — enables swap-to-OKB in onboarding) ---
# Without these, onboarding shows indicative quotes; the rest of Clerk runs fine.
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

# --- Gas sponsorship (OPTIONAL — Clerk covers merchant gas so they never need OKB) ---
# One-time drip per wallet address (enforced in Supabase gas_drips), capped daily.
# Tune GAS_DRIP_WEI to comfortably cover registerMerchant() + one reopen() on X Layer.
GAS_DRIP_WEI=1000000000000000       # default 0.001 OKB
GAS_DRIP_DAILY_CAP=200               # max drips per rolling 24h across all wallets
