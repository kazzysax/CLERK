{
  "name": "clerk-io",
  "version": "1.0.0",
  "description": "clerk.io — outcome-paid AI support agent on X Layer (OKX). Contract, backend, and deploy scripts.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "hardhat test --config hardhat.test.config.cjs",
    "test:conversation": "node conversation.test.mjs",
    "deploy:testnet": "hardhat run scripts/deploy-reputation.cjs --config hardhat.config.cjs --network xlayerTestnet",
    "deploy:mainnet": "hardhat run scripts/deploy-reputation.cjs --config hardhat.config.cjs --network xlayer",
    "deploy:v2:testnet": "hardhat run scripts/deploy-v2.cjs --config hardhat.config.cjs --network xlayerTestnet",
    "start": "node server.mjs"
  },
  "keywords": [
    "clerk",
    "x-layer",
    "okx",
    "ai-agent"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "dotenv": "^17.4.2",
    "ethers": "^6.17.0",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "chai": "^4.5.0",
    "hardhat": "^2.28.6",
    "mocha": "^11.7.6",
    "solc": "^0.8.24"
  }
}
